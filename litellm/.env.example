# ==================== LITELLM PROXY SETTINGS ====================
# Master key for admin access
LITELLM_MASTER_KEY=KEY_AAAA

# Salt key for encrypting API keys (CANNOT be changed after models are added)
# Generate a random hash using: https://1password.com/password-generator/
LITELLM_SALT_KEY=KEY_AAAA

# Database
POSTGRES_USER=USER_AAA
POSTGRES_PASSWORD=PASSWORD_AAA
POSTGRES_DB: litellm

### UI
UI_USERNAME=NAME_AAAA
UI_PASSWORD=KEY_AAAA

# ==================== API KEYS FOR PROVIDERS ====================

# OpenRouter
OPENROUTER_API_KEY=KEY_AAAA

# Z.AI (Zhipu AI)
ZAI_API_KEY=KEY_AAAA
ZAI_API_BASE=https://api.z.ai/api/coding/paas/v4

# DeepSeek
DEEPSEEK_API_KEY=KEY_AAAA

# Mistral AI
MISTRAL_API_KEY=KEY_AAAA

# Groq
GROQ_API_KEY=KEY_AAAA

# Alibaba Dashscope (Qwen)
DASHSCOPE_API_KEY=KEY_AAAA
DASHSCOPE_API_BASE=KEY_AAAA

# Google / Vertex AI (choose one method)
# Method 1: Using GEMINI_API_KEY (simple API key)
GEMINI_API_KEY=KEY_AAAA

# Method 2: Using Vertex AI with service account (uncomment and configure)
# VERTEXAI_PROJECT=your-gcp-project-id
# VERTEXAI_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service_account.json

# ==================== LOCAL PROVIDER URLS ====================

# LlamaCPP (OpenAI-compatible local server)
# Example: Local llama.cpp server running on port 8080
LLAMACPP_API_BASE=https://URL_AAA/v1

# Ollama (default is localhost:11434)
# If Ollama is running on a different host/port:
OLLAMA_API_BASE=URL_AAA
